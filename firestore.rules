rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /sessions/{sessionId} {
      allow read, delete: if isExistingOwner();
      allow create: if isSignedIn()
                    && hasAllowedFields(request.resource.data)
                    && hasRequiredFields(request.resource.data)
                    && isValidSession(request.resource.data)
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.id == sessionId;
      allow update: if isExistingOwner()
                    && hasAllowedFields(request.resource.data)
                    && hasRequiredFields(request.resource.data)
                    && isValidSession(request.resource.data)
                    && request.resource.data.userId == resource.data.userId
                    && request.resource.data.id == resource.data.id;

      function isSignedIn() {
        return request.auth != null;
      }

      function isExistingOwner() {
        return isSignedIn() && resource.data.userId == request.auth.uid;
      }

      function hasAllowedFields(session) {
        return session.keys().hasOnly([
          'id',
          'categoryId',
          'title',
          'date',
          'time',
          'duration',
          'notes',
          'createdAt',
          'updatedAt',
          'userId'
        ]);
      }

      function hasRequiredFields(session) {
        return session.keys().hasAll([
          'id',
          'categoryId',
          'title',
          'date',
          'time',
          'duration',
          'userId'
        ]);
      }

      function isValidSession(session) {
        return session.id is string
               && session.id.size() > 0
               && session.id.size() <= 128
               && session.categoryId is string
               && session.categoryId.size() > 0
               && session.categoryId.size() <= 64
               && session.title is string
               && session.title.size() > 0
               && session.title.size() <= 120
               && session.date is string
               && session.date.matches('^\\d{4}-\\d{2}-\\d{2}$')
               && session.time is string
               && session.time.size() > 0
               && session.time.size() <= 32
               && session.duration is int
               && session.duration > 0
               && session.duration <= 720
               && session.userId is string
               && session.userId.size() > 0
               && session.userId.size() <= 128
               && (!session.keys().hasAny(['notes'])
                   || (session.notes is string && session.notes.size() <= 4000))
               && (!session.keys().hasAny(['createdAt'])
                   || (session.createdAt is string && session.createdAt.size() <= 64))
               && (!session.keys().hasAny(['updatedAt'])
                   || (session.updatedAt is string && session.updatedAt.size() <= 64));
      }
    }
  }
}
