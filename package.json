{
  "name": "teatime-accessibility",
  "productName": "TeaTime",
  "private": true,
  "version": "1.0.0",
  "description": "Discipline equals freedom - TeaTime helps you build daily discipline through structured breaks",
  "author": "genidma",
  "main": "main.js",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "electron-dev": "electron .",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "pack": "electron-builder --dir",
    "dist": "vite build && electron-builder",
    "dist:win": "vite build && electron-builder --win",
    "dist:mac": "vite build && electron-builder --mac"
  },
  "dependencies": {
    "@google/genai": "^1.48.0",
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-react": "^5.2.0",
    "dotenv": "^17.4.1",
    "express": "^4.22.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.38.0",
    "node": "^25.9.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-is": "^19.2.5",
    "recharts": "^3.8.1",
    "sql.js": "^1.14.1",
    "vite": "^6.4.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/express": "^4.17.25",
    "@types/node": "^22.19.17",
    "autoprefixer": "^10.4.27",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.4.2"
  },
  "build": {
    "appId": "com.teatime.app",
    "productName": "TeaTime",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.icns"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
